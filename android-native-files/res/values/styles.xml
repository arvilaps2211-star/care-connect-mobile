<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme with notch/cutout support -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Status bar & navigation bar match app primary color -->
        <item name="android:statusBarColor">#3b82f6</item>
        <item name="android:navigationBarColor">#3b82f6</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Edge-to-edge: extend content into notch/cutout area -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:fitsSystemWindows">false</item>

        <!-- Background fills entire screen including notch -->
        <item name="android:windowBackground">#3b82f6</item>
    </style>

    <!-- Launch / splash theme -->
    <style name="AppTheme.NoActionBarLaunch" parent="AppTheme">
        <item name="android:background">#3b82f6</item>
    </style>
</resources>
